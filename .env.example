# ─── Supabase ────────────────────────────────────────────────────────────────────
# Either set of names works (legacy on the right is read as fallback):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=     # or NEXT_PUBLIC_SUPABASE_ANON_KEY
SECRET_KEY=                                # or SUPABASE_SERVICE_ROLE_KEY

# ─── Resend (transactional + campaign email) ────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@connectex.net

# ─── Google Workspace (OAuth — calendar sync, Gmail send for sequences) ─────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=                       # e.g. https://connectex.net/api/google/callback

# ─── Gemini (AI triage, campaign / blog AI assist) ────────────────────────────────
GEMINI_API_KEY=

# ─── Application ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://connectex.net
NEXT_PUBLIC_SITE_URL=https://connectex.net  # used in transactional email links

# ─── Cron (Vercel cron hits /api/cron/*) ────────────────────────────────────────────
CRON_SECRET=                               # REQUIRED — cron routes fail-closed if unset

# ─── Security ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
